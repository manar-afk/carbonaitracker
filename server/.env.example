# App execution port
PORT=5000

# JSON Web Token secret key (use a long random alphanumeric string in production)
JWT_SECRET=YOUR_JWT_SECRET_HERE

# Google Gemini API Key from Google AI Studio (required for live recommendations)
# If left blank or as default, the server falls back to high-fidelity local heuristics
GEMINI_API_KEY=YOUR_GEMINI_API_KEY_HERE

# Google Sign-In Credentials (must match client VITE_GOOGLE_CLIENT_ID)
# Required for Google token authentication on backend
GOOGLE_CLIENT_ID=YOUR_GOOGLE_CLIENT_ID_HERE
